
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isHardcodedAdmin() {
      return isSignedIn() && request.auth.uid == "Q3AAJKZAPvZYvcTEkLatjWP1ftD2";
    }

    function isAdmin() {
      // Prioritize the hardcoded bypass for immediate, guaranteed access.
      return isHardcodedAdmin() || (
        isSignedIn() && 
        exists(/databases/(default)/documents/admin_roles/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    // Admin Roles - ISOLATED to prevent recursion
    match /admin_roles/{adminUid} {
      // Users can always read their own status. 
      // We avoid calling isAdmin() here to break the infinite recursion loop.
      allow read: if isSignedIn() && (request.auth.uid == adminUid || isHardcodedAdmin());
      allow write: if isHardcodedAdmin();
    }

    // User Profiles & Subcollections
    match /users/{userId} {
      allow read, write: if isSignedIn() && (isOwner(userId) || isAdmin());
      
      match /addresses/{addressId} {
        allow read, write: if isSignedIn() && (isOwner(userId) || isAdmin());
      }

      match /userRewards/{userRewardId} {
        allow read, write: if isSignedIn() && (isOwner(userId) || isAdmin());
      }
    }

    // Public Collections
    match /products/{id} { allow read: if true; }
    match /categories/{id} { allow read: if true; }
    match /pairings/{id} { allow read: if true; }
    match /rewards/{id} { allow read: if true; }
    match /settings/{id} { allow read: if true; }

    // Orders - Supports Guest Checkout
    match /orders/{orderId} {
      // List remains restricted to authenticated owners or admins
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      
      // Allow get if owner, admin, or if it's a guest order (access via ID)
      allow get: if (isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid)) || resource.data.userId == "guest";
      
      // Allow anyone to create an order (supports guest checkout)
      allow create: if true;
      
      // Only admins can modify existing orders
      allow update, delete: if isAdmin();

      match /orderItems/{orderItemId} {
        // Items inherit the parent order's access logic
        allow read: if (isSignedIn() && (isAdmin() || get(/databases/(default)/documents/orders/$(orderId)).data.userId == request.auth.uid)) || get(/databases/(default)/documents/orders/$(orderId)).data.userId == "guest";
      }
    }

    // Chat Sessions
    match /chatSessions/{chatSessionId} {
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid || resource.data.agentId == request.auth.uid);
      allow get, update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid || resource.data.agentId == request.auth.uid);
      allow create: if isSignedIn();

      match /messages/{messageId} {
        allow read, create: if isSignedIn();
      }
    }

    // Drivers
    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == driverId);
    }

    // Global Admin Bypass for all other collections and operations not matched above
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
